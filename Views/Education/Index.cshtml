@using PersonalWebsite.Models
@model List<Education>
@{
    ViewData["Title"] = "Utbildning";
}

<div class="container py-5">
    <h1 class="section-title mb-5">Utbildning</h1>

    @foreach (var edu in Model)
    {
        <div class="timeline-item">
            <div class="d-flex align-items-center mb-1">
                <div class="timeline-dot"></div>
                <h5 class="mb-0 ms-2">@edu.Degree</h5>
            </div>
            <p class="text-primary fw-semibold mb-1">@edu.School</p>
            <p class="text-muted small mb-2">
                @edu.StartYear – @(edu.EndYear.HasValue ? edu.EndYear.Value.ToString() : "Pågående")
            </p>
            @if (!string.IsNullOrEmpty(edu.Description))
            {
                <p class="text-muted">@edu.Description</p>
            }

            @if (edu.Courses.Any())
            {
                <h6 class="mt-3 mb-2 fw-bold">Kurser</h6>
                <div class="row g-3">
                    @foreach (var course in edu.Courses.OrderBy(c => c.StartDate))
                    {
                        <div class="col-md-6">
                            <div class="card p-3">
                                <div class="d-flex justify-content-between align-items-start">
                                    <h6 class="mb-1 fw-semibold">@course.Name</h6>
                                    @if (!string.IsNullOrEmpty(course.Grade))
                                    {
                                        <span class="badge bg-dark ms-2">@course.Grade</span>
                                    }
                                </div>
                                @if (course.StartDate.HasValue)
                                {
                                    <p class="text-muted small mb-1">@course.StartDate.Value.ToString("yyyy-MM-dd")</p>
                                }
                                @if (!string.IsNullOrEmpty(course.Description))
                                {
                                    <p class="text-muted small mb-0">@course.Description</p>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>
