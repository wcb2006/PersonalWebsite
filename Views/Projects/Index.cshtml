@using PersonalWebsite.Models
@model List<Project>
@{
    ViewData["Title"] = "Projekt";
}

<div class="container py-5">
    <h1 class="section-title mb-5">Mina Projekt</h1>

    @if (!Model.Any())
    {
        <p class="text-muted">Inga projekt tillagda än.</p>
    }
    else
    {
        <div class="row g-4">
            @foreach (var project in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100">
                        @if (!string.IsNullOrEmpty(project.ImageUrl))
                        {
                            <img src="@project.ImageUrl" class="card-img-top" alt="@project.Title" style="height:200px;object-fit:cover;" />
                        }
                        else
                        {
                            <div class="d-flex align-items-center justify-content-center bg-dark text-white rounded-top" style="height:200px;font-size:3rem;">💻</div>
                        }
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title mb-0">@project.Title</h5>
                                <span class="badge bg-secondary">@project.Year</span>
                            </div>
                            <p class="card-text text-muted flex-grow-1">@project.Description</p>
                            @if (!string.IsNullOrEmpty(project.Technologies))
                            {
                                <div class="mt-2">
                                    @foreach (var tech in project.Technologies.Split(','))
                                    {
                                        <span class="badge bg-primary me-1">@tech.Trim()</span>
                                    }
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(project.ProjectUrl))
                            {
                                <a href="@project.ProjectUrl" target="_blank" class="btn btn-sm btn-outline-dark mt-3">Visa projekt →</a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
