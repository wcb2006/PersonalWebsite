@using PersonalWebsite.Models
@using PersonalWebsite.ViewModels
@model HomeViewModel
@{
    ViewData["Title"] = "Om mig";
    var about = Model.About;
}

<style>
    /* ── Slideshow ── */
    .slideshow-section {
        background: #0d0d0d;
        padding: 70px 0;
    }
    .slideshow-wrapper { position: relative; overflow: hidden; }
    .slides-track { display: flex; transition: transform 0.6s cubic-bezier(0.77,0,0.18,1); }
    .slide { min-width: 100%; padding: 0 60px; box-sizing: border-box; }
    .project-card-inner {
        position: relative; border-radius: 20px; overflow: hidden;
        cursor: pointer; max-width: 900px; margin: 0 auto;
        aspect-ratio: 16/9; background: #1a1a1a;
        box-shadow: 0 30px 80px rgba(0,0,0,0.6);
    }
    .project-card-inner img { width:100%; height:100%; object-fit:cover; display:block; transition: transform 0.5s; }
    .project-card-inner:hover img { transform: scale(1.04); }
    .project-no-image { width:100%; height:100%; display:flex; align-items:center; justify-content:center; font-size:5rem; background: linear-gradient(135deg,#1a1a2e,#0f3460); }
    .project-overlay {
        position:absolute; bottom:0; left:0; right:0;
        background: linear-gradient(to top, rgba(0,0,0,0.92) 0%, rgba(0,0,0,0.4) 60%, transparent 100%);
        padding: 40px 40px 30px; color: white;
    }
    .project-overlay h2 { font-size:2rem; font-weight:700; margin-bottom:8px; }
    .project-overlay p { font-size:1rem; opacity:0.8; margin-bottom:14px; max-width:600px; }
    .project-link-btn {
        display:inline-block; padding:10px 24px; background:white; color:#0d0d0d;
        border-radius:50px; font-weight:600; font-size:0.9rem; text-decoration:none; transition:0.2s;
    }
    .project-link-btn:hover { background:#e0e0e0; transform:scale(1.05); color:#0d0d0d; }
    .year-badge {
        position:absolute; top:20px; right:20px;
        background:rgba(255,255,255,0.15); backdrop-filter:blur(8px);
        color:white; padding:5px 14px; border-radius:50px; font-size:0.85rem; font-weight:600;
    }
    .tech-badge {
        display:inline-block; background:rgba(255,255,255,0.15); backdrop-filter:blur(4px);
        color:white; padding:3px 12px; border-radius:50px; font-size:0.78rem; margin-right:6px; margin-bottom:6px;
    }
    .slide-btn {
        position:absolute; top:50%; transform:translateY(-50%);
        background:rgba(255,255,255,0.1); backdrop-filter:blur(6px);
        border:1px solid rgba(255,255,255,0.2); color:white;
        width:52px; height:52px; border-radius:50%; font-size:1.3rem;
        display:flex; align-items:center; justify-content:center;
        cursor:pointer; z-index:10; transition:background 0.2s; user-select:none;
    }
    .slide-btn:hover { background:rgba(255,255,255,0.25); }
    .slide-btn.prev { left:12px; }
    .slide-btn.next { right:12px; }
    .slide-dots { display:flex; justify-content:center; gap:10px; margin-top:24px; }
    .dot { width:8px; height:8px; border-radius:50%; background:rgba(255,255,255,0.25); cursor:pointer; transition:0.3s; }
    .dot.active { background:white; transform:scale(1.3); }
    .slide-counter { text-align:center; color:rgba(255,255,255,0.4); font-size:0.85rem; margin-top:10px; letter-spacing:2px; }
    .slideshow-header { text-align:center; color:white; margin-bottom:36px; }
    .slideshow-header h2 { font-size:2rem; font-weight:700; }
    .slideshow-header p { color:rgba(255,255,255,0.4); font-size:0.95rem; }
</style>

<!-- Hero -->
<div class="hero-section">
    <div class="container text-center">
        @if (!string.IsNullOrEmpty(about?.ProfileImageUrl))
        {
            <img src="@about.ProfileImageUrl" alt="Profilbild" class="rounded-circle mb-4"
                 style="width:140px;height:140px;object-fit:cover;border:4px solid white;" />
        }
        else
        {
            <div class="rounded-circle bg-secondary d-inline-flex align-items-center justify-content-center mb-4"
                 style="width:140px;height:140px;font-size:3rem;color:white;">
                @(about?.Name.FirstOrDefault())
            </div>
        }
        <h1 class="display-4 fw-bold">@about?.Name</h1>
        <p class="lead text-white-50">@about?.Title</p>
        <div class="mt-3">
            @if (!string.IsNullOrEmpty(about?.GithubUrl))
            {
                <a href="@about.GithubUrl" target="_blank" class="btn btn-outline-light me-2">GitHub</a>
            }
            @if (!string.IsNullOrEmpty(about?.LinkedInUrl))
            {
                <a href="@about.LinkedInUrl" target="_blank" class="btn btn-outline-light">LinkedIn</a>
            }
        </div>
    </div>
</div>

<!-- Om mig -->
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <h2 class="section-title mb-4">Om mig</h2>
            <p class="lead">@about?.Bio</p>
        </div>
    </div>
</div>

<!-- Kompetenser -->
<div style="background:#f0f2f5; padding: 60px 0;">
    <div class="container">
        <h2 class="section-title mb-5 text-center" style="border-left:none; padding-left:0;">Kompetenser</h2>
        <div class="row g-4 justify-content-center">
            @{
                var skills = new[]
                {
                    new { Name = "Python",     Icon = "devicon-python-plain colored" },
                    new { Name = "C#",         Icon = "devicon-csharp-plain colored" },
                    new { Name = "SQL",        Icon = "devicon-postgresql-plain colored" },
                    new { Name = "HTML",       Icon = "devicon-html5-plain colored" },
                    new { Name = "CSS",        Icon = "devicon-css3-plain colored" },
                    new { Name = "JavaScript", Icon = "devicon-javascript-plain colored" },
                    new { Name = "React",      Icon = "devicon-react-original colored" },
                    new { Name = "Git",        Icon = "devicon-git-plain colored" },
                    new { Name = "MongoDB",    Icon = "devicon-mongodb-plain colored" },
                };
            }
            @foreach (var skill in skills)
            {
                <div class="col-6 col-sm-4 col-md-3">
                    <div class="card p-4 text-center h-100">
                        <i class="@skill.Icon" style="font-size:3.5rem;"></i>
                        <p class="mb-0 mt-3 fw-semibold">@skill.Name</p>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Projekt slideshow -->
@if (Model.Projects.Any())
{
    <div class="slideshow-section">
        <div class="slideshow-header">
            <h2>Mina Projekt</h2>
            <p>Klicka för att besöka — använd pilarna eller tangentbordets ← →</p>
        </div>

        <div class="slideshow-wrapper">
            <button class="slide-btn prev" onclick="changeSlide(-1)">&#8592;</button>
            <button class="slide-btn next" onclick="changeSlide(1)">&#8594;</button>

            <div class="slides-track" id="slidesTrack">
                @foreach (var project in Model.Projects)
                {
                    <div class="slide">
                        @if (!string.IsNullOrEmpty(project.ProjectUrl))
                        {
                            <a href="@project.ProjectUrl" target="_blank" class="project-card-inner d-block text-decoration-none">
                                @if (!string.IsNullOrEmpty(project.ImageUrl))
                                {
                                    <img src="@project.ImageUrl" alt="@project.Title" />
                                }
                                else
                                {
                                    <div class="project-no-image">💻</div>
                                }
                                <span class="year-badge">@project.Year</span>
                                <div class="project-overlay">
                                    @if (!string.IsNullOrEmpty(project.Technologies))
                                    {
                                        <div class="mb-2">
                                            @foreach (var tech in project.Technologies.Split(','))
                                            {
                                                <span class="tech-badge">@tech.Trim()</span>
                                            }
                                        </div>
                                    }
                                    <h2>@project.Title</h2>
                                    <p>@project.Description</p>
                                    <span class="project-link-btn">Besök projekt →</span>
                                </div>
                            </a>
                        }
                        else
                        {
                            <div class="project-card-inner">
                                @if (!string.IsNullOrEmpty(project.ImageUrl))
                                {
                                    <img src="@project.ImageUrl" alt="@project.Title" />
                                }
                                else
                                {
                                    <div class="project-no-image">💻</div>
                                }
                                <span class="year-badge">@project.Year</span>
                                <div class="project-overlay">
                                    @if (!string.IsNullOrEmpty(project.Technologies))
                                    {
                                        <div class="mb-2">
                                            @foreach (var tech in project.Technologies.Split(','))
                                            {
                                                <span class="tech-badge">@tech.Trim()</span>
                                            }
                                        </div>
                                    }
                                    <h2>@project.Title</h2>
                                    <p>@project.Description</p>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="slide-dots" id="slideDots">
            @for (int i = 0; i < Model.Projects.Count; i++)
            {
                <div class="dot @(i == 0 ? "active" : "")" onclick="goToSlide(@i)"></div>
            }
        </div>
        <div class="slide-counter"><span id="currentSlide">1</span> / @Model.Projects.Count</div>
    </div>
}

<!-- Snabblänkar -->
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="row g-4">
                <div class="col-md-4">
                    <a asp-controller="Projects" asp-action="Index" class="text-decoration-none">
                        <div class="card p-4 text-center h-100">
                            <div class="fs-1 mb-2">💻</div>
                            <h5>Alla projekt</h5>
                            <p class="text-muted small">Se alla mina projekt</p>
                        </div>
                    </a>
                </div>
                <div class="col-md-4">
                    <a asp-controller="Cv" asp-action="Index" class="text-decoration-none">
                        <div class="card p-4 text-center h-100">
                            <div class="fs-1 mb-2">📄</div>
                            <h5>CV</h5>
                            <p class="text-muted small">Erfarenheter och utbildning</p>
                        </div>
                    </a>
                </div>
                <div class="col-md-4">
                    <a asp-controller="Contact" asp-action="Index" class="text-decoration-none">
                        <div class="card p-4 text-center h-100">
                            <div class="fs-1 mb-2">✉️</div>
                            <h5>Kontakt</h5>
                            <p class="text-muted small">Skicka ett meddelande</p>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let current = 0;
    const total = @Model.Projects.Count;
    const track = document.getElementById('slidesTrack');
    const dots = document.querySelectorAll('.dot');
    const counter = document.getElementById('currentSlide');

    function goToSlide(n) {
        current = (n + total) % total;
        track.style.transform = `translateX(-${current * 100}%)`;
        dots.forEach((d, i) => d.classList.toggle('active', i === current));
        counter.textContent = current + 1;
    }

    function changeSlide(dir) { goToSlide(current + dir); }

    let touchStartX = 0;
    track.addEventListener('touchstart', e => touchStartX = e.touches[0].clientX);
    track.addEventListener('touchend', e => {
        const diff = touchStartX - e.changedTouches[0].clientX;
        if (Math.abs(diff) > 50) changeSlide(diff > 0 ? 1 : -1);
    });

    document.addEventListener('keydown', e => {
        if (e.key === 'ArrowRight') changeSlide(1);
        if (e.key === 'ArrowLeft') changeSlide(-1);
    });
</script>
}
