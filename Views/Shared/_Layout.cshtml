<!DOCTYPE html>
<html lang="sv">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Min Hemsida</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PersonalWebsite.styles.css" asp-append-version="true" />
    <style>
        @@keyframes gradientMove {
            0%   { background-position: 0% 0%; }
            25%  { background-position: 100% 0%; }
            50%  { background-position: 100% 100%; }
            75%  { background-position: 0% 100%; }
            100% { background-position: 0% 0%; }
        }

        body { background-color: #f8f9fa; }
        .navbar-brand { font-weight: 700; font-size: 1.4rem; }
        .hero-section {
            background: #1a1a1a;
            color: white; padding: 80px 0;
            position: relative;
            overflow: clip;
        }
        .hero-section > * { position: relative; z-index: 1; }
        .hero-blob {
            position: absolute;
            border-radius: 50%;
            filter: blur(40px);
            pointer-events: none;
            z-index: 0;
        }
        .blob-yellow {
            width: 40%; height: 200%;
            top: -60%; left: -10%;
            background: rgba(180, 180, 180, 0.3);
            animation: blobA 20s ease-in-out infinite alternate;
        }
        .blob-blue {
            width: 60%; height: 250%;
            top: -80%; left: 15%;
            background: rgba(100, 100, 100, 0.4);
            animation: blobB 26s ease-in-out infinite alternate;
        }
        .blob-dark {
            width: 50%; height: 220%;
            bottom: -80%; right: -10%;
            background: rgba(0, 0, 0, 0.5);
            animation: blobC 18s ease-in-out infinite alternate;
        }
        @@keyframes blobA {
            0%   { transform: translate(0%, 0%) scale(1); }
            50%  { transform: translate(30%, 10%) scale(1.15); }
            100% { transform: translate(10%, -15%) scale(0.9); }
        }
        @@keyframes blobB {
            0%   { transform: translate(0%, 0%) scale(1); }
            40%  { transform: translate(-15%, 12%) scale(1.2); }
            100% { transform: translate(-8%, -10%) scale(0.92); }
        }
        @@keyframes blobC {
            0%   { transform: translate(0%, 0%) scale(1); }
            60%  { transform: translate(20%, -20%) scale(1.1); }
            100% { transform: translate(-25%, 10%) scale(1.18); }
        }
        .card { border: none; box-shadow: 0 2px 8px rgba(0,0,0,0.08); border-radius: 12px; transition: transform 0.2s; }
        .card:hover { transform: translateY(-3px); }
        .section-title { font-weight: 700; color: #333; border-left: 4px solid #666; padding-left: 12px; }
        .timeline-item { border-left: 3px solid #444; padding-left: 20px; margin-bottom: 30px; }
        .timeline-dot { width: 12px; height: 12px; background: #444; border-radius: 50%; margin-left: -26px; margin-top: 6px; float: left; }
        .animated-bg {
            background: #1a1a1a;
        }
        footer { background: #1a1a1a; color: #aaa; padding: 20px 0; margin-top: 60px; }
        footer a { color: #ccc; }

        /* Navbar hide/show on scroll */
        header {
            position: sticky;
            top: 0;
            z-index: 1000;
            transition: transform 0.35s ease;
        }
        header.nav-hidden {
            transform: translateY(-100%);
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-md navbar-light" style="background-color: white;">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">Wille</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Om mig</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" asp-controller="Projects" asp-action="Index">Projekt</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Projects" asp-action="Index" asp-route-category="school">Skolprojekt</a></li>
                                <li><a class="dropdown-item" asp-controller="Projects" asp-action="Index" asp-route-category="personal">Mina projekt</a></li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Cv" asp-action="Index">CV</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Contact" asp-action="Index">Kontakt</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Education" asp-action="Index">Utbildning</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer class="animated-bg">
        <div class="container text-center">
            <p class="mb-0">&copy; @DateTime.Now.Year Wille. Byggd med ASP.NET Core &amp; PostgreSQL.</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        (function () {
            const header = document.querySelector('header');
            let lastY = 0;
            window.addEventListener('scroll', () => {
                const y = window.scrollY;
                header.classList.toggle('nav-hidden', y > lastY && y > 80);
                lastY = y;
            });
        })();
    </script>
</body>
</html>
