<!DOCTYPE html>
<html lang="sv">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Min Hemsida</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PersonalWebsite.styles.css" asp-append-version="true" />
    <style>
        body { background-color: #f8f9fa; }
        .navbar-brand { font-weight: 700; font-size: 1.4rem; }
        .hero-section { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%); color: white; padding: 80px 0; }
        .card { border: none; box-shadow: 0 2px 8px rgba(0,0,0,0.08); border-radius: 12px; transition: transform 0.2s; }
        .card:hover { transform: translateY(-3px); }
        .section-title { font-weight: 700; color: #1a1a2e; border-left: 4px solid #0f3460; padding-left: 12px; }
        .timeline-item { border-left: 3px solid #0f3460; padding-left: 20px; margin-bottom: 30px; }
        .timeline-dot { width: 12px; height: 12px; background: #0f3460; border-radius: 50%; margin-left: -26px; margin-top: 6px; float: left; }
        footer { background-color: #1a1a2e; color: #aaa; padding: 20px 0; margin-top: 60px; }
        footer a { color: #ccc; }

        /* Navbar hide/show on scroll */
        header {
            position: sticky;
            top: 0;
            z-index: 1000;
            transition: transform 0.35s ease;
        }
        header.nav-hidden {
            transform: translateY(-100%);
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-md navbar-dark" style="background-color: #1a1a2e;">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">Wille</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Om mig</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Projects" asp-action="Index">Projekt</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Cv" asp-action="Index">CV</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Contact" asp-action="Index">Kontakt</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer>
        <div class="container text-center">
            <p class="mb-0">&copy; @DateTime.Now.Year Wille. Byggd med ASP.NET Core &amp; PostgreSQL.</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        (function () {
            const header = document.querySelector('header');
            let lastY = 0;
            window.addEventListener('scroll', () => {
                const y = window.scrollY;
                header.classList.toggle('nav-hidden', y > lastY && y > 80);
                lastY = y;
            });
        })();
    </script>
</body>
</html>
