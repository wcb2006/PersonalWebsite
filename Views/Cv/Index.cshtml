@using PersonalWebsite.ViewModels
@model CvViewModel
@{
    ViewData["Title"] = "CV";
}

<div class="container py-5">
    <div class="d-flex align-items-center justify-content-between mb-5 flex-wrap gap-3">
        <h1 class="section-title mb-0">CV – William Borg</h1>
        <div>
            <a href="/cv.pdf" target="_blank" class="btn btn-outline-dark me-2">Visa CV</a>
            <a href="/cv.pdf" download="CV William Borg.pdf" class="btn btn-dark">Ladda ner CV</a>
        </div>
    </div>

    <div class="row g-5">
        <!-- Erfarenhet -->
        <div class="col-lg-8">
            <h2 class="section-title mb-4">Arbetslivserfarenhet</h2>
            @foreach (var exp in Model.Experiences)
            {
                <div class="timeline-item">
                    <div class="d-flex align-items-center mb-1">
                        <div class="timeline-dot"></div>
                        <h5 class="mb-0 ms-2">@exp.Role</h5>
                    </div>
                    <p class="text-primary fw-semibold mb-1">@exp.Company</p>
                    <p class="text-muted small mb-2">
                        @exp.StartDate.ToString("MMM yyyy") –
                        @(exp.EndDate.HasValue ? exp.EndDate.Value.ToString("MMM yyyy") : "Aktuell")
                    </p>
                    @if (!string.IsNullOrEmpty(exp.Description))
                    {
                        <p class="mb-0 text-muted">@exp.Description</p>
                    }
                </div>
            }

            <h2 class="section-title mt-5 mb-4">Utbildning</h2>
            @foreach (var edu in Model.Educations)
            {
                <div class="timeline-item">
                    <div class="d-flex align-items-center mb-1">
                        <div class="timeline-dot"></div>
                        <h5 class="mb-0 ms-2">@edu.Degree</h5>
                    </div>
                    <p class="text-primary fw-semibold mb-1">@edu.School</p>
                    <p class="text-muted small mb-0">
                        @edu.StartYear – @(edu.EndYear.HasValue ? edu.EndYear.Value.ToString() : "Aktuell")
                    </p>
                </div>
            }
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <!-- Färdigheter -->
            <div class="card p-4 mb-4">
                <h5 class="fw-bold mb-3" style="color:#333;">Färdigheter</h5>
                @foreach (var skill in new[] { "Teamarbete", "Utbildning av kollegor", "Kassahantering", "Kommunikation", "Datahantering", "Kundservice" })
                {
                    <div class="d-flex align-items-center mb-2">
                        <div style="width:8px;height:8px;border-radius:50%;background:#444;flex-shrink:0;"></div>
                        <span class="ms-2">@skill</span>
                    </div>
                }
            </div>

            <!-- Certifikat -->
            <div class="card p-4 mb-4">
                <h5 class="fw-bold mb-3" style="color:#333;">Certifikat</h5>
                <a href="https://www.credly.com/badges/f300179c-6abc-4094-ac81-fde7b32277e8" target="_blank" class="text-decoration-none">
                    <img src="/images/python-cert.jpg" alt="Python Certiport Certificate" class="img-fluid rounded mb-3" style="width:100%;" />
                    <p class="mb-1 fw-semibold text-dark">Python – Certiport</p>
                    <p class="text-muted small mb-0">Pearson VUE Business</p>
                    <p class="text-primary small mt-1">Visa certifikat →</p>
                </a>
            </div>

            <!-- Språk -->
            <div class="card p-4 mb-4">
                <h5 class="fw-bold mb-3" style="color:#333;">Språk</h5>
                <div class="d-flex justify-content-between mb-2">
                    <span>Svenska</span>
                    <span class="badge bg-dark">Inhemsk</span>
                </div>
                <div class="d-flex justify-content-between">
                    <span>Engelska</span>
                    <span class="badge bg-secondary">Avancerad</span>
                </div>
            </div>

            <!-- Kontakt -->
            <div class="card p-4">
                <h5 class="fw-bold mb-3" style="color:#333;">Kontakt</h5>
                <p class="mb-2 small"><strong>Tel:</strong> 070-582 82 22</p>
                <p class="mb-2 small"><strong>E-post:</strong> wille.borg.c@gmail.com</p>
                <p class="mb-2 small"><strong>Ort:</strong> Malmö</p>
                <p class="mb-0 small"><strong>Körkort:</strong> B</p>
            </div>
        </div>
    </div>

    <div class="mt-5 p-4 bg-white rounded-3 shadow-sm text-center">
        <p class="text-muted mb-3">Vill du se hela CV:t som PDF?</p>
        <a href="/cv.pdf" target="_blank" class="btn btn-outline-dark me-2">Öppna PDF</a>
        <a href="/cv.pdf" download="CV William Borg.pdf" class="btn btn-dark">Ladda ner</a>
    </div>
</div>
